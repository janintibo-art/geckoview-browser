<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg"
    android:padding="8dp">

    <LinearLayout
        android:id="@+id/w_search"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_pill"
        android:paddingStart="14dp"
        android:paddingEnd="10dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/widget_search_hint"
            android:textColor="#8A9099"
            android:textSize="14sp"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <ImageView
        android:id="@+id/w_private"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="4dp"
        android:padding="9dp"
        android:src="@android:drawable/ic_secure"
        android:contentDescription="@string/widget_private" />

    <ImageView
        android:id="@+id/w_bookmarks"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:padding="9dp"
        android:src="@android:drawable/btn_star_big_off"
        android:contentDescription="@string/widget_bookmarks" />
</LinearLayout>
