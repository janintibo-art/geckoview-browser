{
  "manifest_version": 2,
  "name": "GeckoBlock",
  "version": "1.1",
  "description": "Blocage de publicites, de traqueurs et moteur de recherche filtre",

  "browser_specific_settings": {
    "gecko": {
      "id": "adblock@geckobrowser"
    }
  },

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "storage",
    "nativeMessaging",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["rules.js", "background.js"],
    "persistent": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "web_accessible_resources": [
    "search.html",
    "search.css",
    "search.js",
    "engines.js",
    "publishers.js"
  ]
}
